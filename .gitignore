# Benchmark generated data, environments, and timestamped results
/benchmarks/data/
/benchmarks/data_real/
/benchmarks/data_large/
/benchmarks/data_large_real/
/benchmarks/correctness/real_data/
/benchmarks/.venv/
/benchmarks/.RData
/benchmarks/.Rhistory

# Keep latest results, ignore timestamped runs
/benchmarks/results/*
!/benchmarks/results/latest/

# Books — ignore all except biostatistics, language, practical-bioinformatics
/books/*
!/books/biostatistics/
!/books/language/
!/books/practical-bioinformatics/

# Extension store listings (local only, not shipped)
/website/extension/*/STORE_LISTING.md
/website/extension/*/dist/STORE_LISTING.md

