# GC Content at Scale: compute GC for every sequence in a large FASTA
let records = fasta("data_real/human_chr22.fa") |> collect()
let gc_values = records |> map(|r| gc_content(r.seq))
let mean_gc = mean(gc_values)
let min_gc = min(gc_values)
let max_gc = max(gc_values)
println(f"Sequences: {len(records)}")
println(f"Mean GC: {round(mean_gc, 4)}")
println(f"Min GC: {round(min_gc, 4)}")
println(f"Max GC: {round(max_gc, 4)}")
