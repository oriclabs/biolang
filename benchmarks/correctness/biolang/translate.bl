# Translate first 3 FASTA sequences (trimmed to multiple of 3). Output JSON.
let seqs = read_fasta("data/contigs.fa") |> head(3)
let results = {}
seqs |> each(|s| {
    let seq = s.seq
    let trim_len = (seq_len(seq) / 3) * 3
    let trimmed = subseq(seq, 0, trim_len)
    let rna = transcribe(trimmed)
    let protein = translate(rna)
    results = merge(results, {[s.id]: str(protein)})
})
let output = {translations: results}
println(json_stringify(output, 2))
