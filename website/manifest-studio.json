{
  "name": "BioLang Studio",
  "short_name": "BioLang Studio",
  "description": "Bioinformatics IDE with database search, code editor, and local file access. Write BioLang code, search NCBI/UniProt/PDB, analyze FASTA/VCF/CSV files — no server needed.",
  "start_url": "/studio.html",
  "display": "standalone",
  "background_color": "#080c14",
  "theme_color": "#7c3aed",
  "orientation": "any",
  "icons": [
    {
      "src": "assets/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "categories": ["science", "developer tools", "productivity"],
  "file_handlers": [
    {
      "action": "/studio.html",
      "accept": {
        "text/plain": [".bl", ".fasta", ".fa", ".fna", ".fastq", ".fq", ".vcf", ".bed", ".gff", ".gff3", ".gtf", ".csv", ".tsv", ".sam", ".txt"]
      }
    }
  ]
}
