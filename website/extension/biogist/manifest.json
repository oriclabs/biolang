{
  "manifest_version": 3,
  "name": "BioGist",
  "short_name": "BioGist",
  "version": "1.0.0",
  "description": "Genomic intelligence, in situ. Auto-detects genes, variants, and datasets on any webpage.",
  "author": { "email": "devking2021@gmail.com" },
  "homepage_url": "https://lang.bio",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "contextMenus",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" },
    "default_title": "BioGist — Toggle sidebar"
  }
}
