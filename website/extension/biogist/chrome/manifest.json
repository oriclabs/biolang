{
  "manifest_version": 3,
  "name": "BioGist",
  "short_name": "BioGist",
  "version": "1.1.0",
  "description": "Get the biological gist of any research paper. Auto-detects genes, variants, and datasets on any webpage.",
  "author": { "email": "devking2021@gmail.com" },
  "homepage_url": "https://lang.bio",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "contextMenus",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" },
    "default_title": "BioGist — Toggle sidebar"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+B", "mac": "Command+Shift+B" },
      "description": "Toggle BioGist sidebar"
    },
    "scan-page": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "Scan current page"
    }
  }
}
