{
  "manifest_version": 3,
  "name": "BioKhoj",
  "short_name": "BioKhoj",
  "version": "1.0.0",
  "description": "Your personal research radar for biology. Monitor genes, drugs, and variants across literature.",
  "author": "Oric Labs",
  "homepage_url": "https://lang.bio/biokhoj",
  "browser_specific_settings": {
    "gecko": {
      "id": "biokhoj@oriclabs.com",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "BioKhoj",
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png" }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png" },
    "default_title": "BioKhoj \u2014 Research Radar"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Toggle BioKhoj sidebar"
    }
  }
}
