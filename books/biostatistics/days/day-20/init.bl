# Day 20: Batch Effects
# Data sources: Leek et al. 2010 Nature Reviews Genetics 11:733-9
#               TCGA BRCA multi-center RNA-seq (batch = sequencing center)
#               Typical batch variance >> biological variance scenario

mkdir("data")

# ============================================================
# 50 genes x 60 samples expression matrix
# 3 centers (A, B, C): 20 samples each (10 tumor + 10 normal)
# Batch effect explains ~40% of variance (center-specific shift)
# Biological effect explains ~15% (tumor vs normal)
# This mirrors the common problem in multi-center genomic studies
# ============================================================

# 50 real gene names from TCGA BRCA (mix of cancer genes and housekeeping)
let gene_names = [
    "ESR1", "PGR", "ERBB2", "MKI67", "TP53",
    "EGFR", "BRCA1", "FOXA1", "GATA3", "CCND1",
    "CDH1", "VIM", "FN1", "MMP2", "MMP9",
    "VEGFA", "PDGFRA", "KIT", "MET", "ALK",
    "PIK3CA", "PTEN", "AKT1", "MTOR", "RB1",
    "CDK4", "CDK6", "CCNB1", "AURKA", "TOP2A",
    "GAPDH", "ACTB", "TUBB", "RPL13A", "RPS18",
    "B2M", "HPRT1", "TBP", "YWHAZ", "SDHA",
    "HMBS", "UBC", "PGK1", "TFRC", "GUSB",
    "PPIA", "RPLP0", "HSP90AA1", "LDHA", "ENO1"
]

# Base expression levels for each gene (log2-TPM, realistic TCGA ranges)
let base_expr = [
    8.5, 6.2, 7.8, 5.1, 6.5,
    5.8, 4.9, 7.3, 8.1, 9.2,
    9.5, 4.2, 5.6, 3.8, 4.1,
    6.7, 3.5, 3.2, 4.8, 2.1,
    5.3, 6.1, 5.8, 6.9, 5.5,
    4.3, 3.9, 4.7, 5.2, 5.8,
    12.5, 13.1, 11.8, 12.2, 12.9,
    11.5, 8.3, 7.6, 10.2, 9.8,
    7.1, 11.3, 10.5, 8.9, 8.2,
    10.8, 11.7, 9.5, 10.1, 10.6
]

# Biological effect per gene (tumor - normal): cancer genes show difference
# Housekeeping genes (31-50) have near-zero biological effect
let bio_effect = [
    1.8, 1.5, 2.1, 1.9, -0.8,
    1.2, -0.6, 1.4, 1.6, 0.9,
    -1.3, 1.7, 1.5, 1.1, 1.3,
    0.8, 0.5, 0.3, 0.7, 0.2,
    0.4, -0.9, 0.3, 0.5, -0.4,
    0.6, 0.5, 1.2, 1.1, 1.0,
    0.05, 0.03, 0.04, 0.02, 0.06,
    0.03, 0.02, 0.04, 0.05, 0.01,
    0.03, 0.02, 0.04, 0.05, 0.03,
    0.02, 0.04, 0.06, 0.03, 0.05
]

# Batch effects per center per gene: STRONG (2-4 units shift)
# Center A: reference (0), Center B: +2.5 shift, Center C: -1.8 shift
# These are MUCH larger than biological effects for most genes
let batch_B = [
    2.8, 2.5, 3.1, 2.3, 2.6,
    2.9, 2.4, 2.7, 3.0, 2.2,
    2.5, 2.8, 2.3, 3.2, 2.6,
    2.4, 2.9, 2.1, 2.7, 3.0,
    2.6, 2.3, 2.8, 2.5, 2.4,
    2.7, 2.9, 2.2, 2.6, 2.3,
    2.1, 2.4, 2.8, 2.5, 2.3,
    2.6, 2.2, 2.7, 2.4, 2.9,
    2.3, 2.5, 2.8, 2.1, 2.6,
    2.4, 2.7, 2.3, 2.5, 2.8
]
let batch_C = [
    -1.9, -2.1, -1.6, -2.3, -1.8,
    -2.0, -1.7, -2.2, -1.5, -2.4,
    -1.8, -2.1, -1.9, -1.6, -2.0,
    -2.3, -1.7, -2.5, -1.8, -1.5,
    -2.1, -1.9, -1.6, -2.0, -2.2,
    -1.8, -1.5, -2.3, -1.7, -2.1,
    -1.9, -1.6, -2.0, -1.8, -2.2,
    -1.7, -2.4, -1.5, -2.1, -1.8,
    -2.0, -1.6, -1.9, -2.3, -1.7,
    -2.1, -1.8, -2.0, -1.5, -1.9
]

# Build header
let header = "sample_id,center,condition"
for g in range(0, 50) {
    header = f"{header},{gene_names[g]}"
}

let lines = [header]

# 60 samples: centers A(1-20), B(21-40), C(41-60)
# Within each center: samples 1-10 = tumor, 11-20 = normal
for s in range(0, 60) {
    let center_idx = s / 20  # 0, 1, 2
    let within = s % 20
    let is_tumor = within < 10
    let center = if center_idx == 0 { "A" } else if center_idx == 1 { "B" } else { "C" }
    let condition = if is_tumor { "tumor" } else { "normal" }
    let sample_id = f"{center}_{condition}_{(within % 10) + 1:02}"

    let row = f"{sample_id},{center},{condition}"

    for g in range(0, 50) {
        let base = base_expr[g]
        # Add batch effect
        let batch = if center_idx == 0 { 0.0 }
                    else if center_idx == 1 { batch_B[g] }
                    else { batch_C[g] }
        # Add biological effect (tumor only)
        let bio = if is_tumor { bio_effect[g] } else { 0.0 }
        # Add sample-level noise (small relative to batch)
        let noise = ((s * 50 + g) * 2654435761 % 1000) / 1000.0 - 0.5
        let expr = round(base + batch + bio + noise * 0.6, 2)
        row = f"{row},{expr}"
    }

    lines = append(lines, row)
}

write_lines(lines, "data/batch_expression.csv")
println("Wrote data/batch_expression.csv: 50 genes x 60 samples")
println("  3 centers (A, B, C), 10 tumor + 10 normal each")
println("  Batch effect: ~2.5 log2 units (explains ~40% variance)")
println("  Biological effect: ~1.0 log2 units (explains ~15% variance)")
println("  PCA will show samples cluster by CENTER, not by condition")
println("")
println("Day 20 data ready: batch effect detection and correction")
