# Day 29: Capstone — Differential Expression Study
# Data sources:
#   TCGA COAD (Colon Adenocarcinoma) RNA-seq expression patterns
#   Gene names from HGNC; top DE genes from TCGA COAD tumor vs matched normal
#   Upregulated in tumor: MYC, VEGFA, MMP7, REG4, CDH17, CLDN1, LGR5
#   Downregulated in tumor: MUC2, AQP8, CA1, SLC26A3, CLCA4, ZG16, MS4A12
#   Housekeeping: ACTB, GAPDH, B2M, RPL13A (stable across conditions)
#   Counts simulate ~20M read RNA-seq depth with negative binomial dispersion

println("Setting up Day 29: Capstone — Differential Expression")
mkdir("data")

# ── File 1: Sample metadata (12 samples, 6 matched pairs) ──
let meta_lines = ["sample_id,condition,patient_id"]
for p in range(1, 7) {
    meta_lines = append(meta_lines, f"normal_{p},normal,patient_{p}")
}
for p in range(1, 7) {
    meta_lines = append(meta_lines, f"tumor_{p},tumor,patient_{p}")
}
write_lines(meta_lines, "data/sample_info.csv")

# ── 200 real gene names with specific expression patterns ──
let named_genes = [
