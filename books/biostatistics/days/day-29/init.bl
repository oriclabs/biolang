    "UBE2C", "CENPA", "BIRC5", "FOXM1",
    # Downregulated in tumor (70-119): 50 genes, FC 0.05-0.5x
    "MUC2", "AQP8", "CA1", "SLC26A3", "CLCA4", "ZG16", "MS4A12", "BEST4",
    "SCIN", "CEACAM7", "CA2", "CA4", "AQP3", "GUCA2A", "GUCA2B", "GCG",
    "PYY", "SST", "TPH1", "CHGA", "SLC5A1", "SI", "TRPM6", "SLC9A3",
    "ABCB1", "NR3C2", "HSD11B2", "SCNN1A", "CFTR", "SLC4A4",
    "ADH1C", "ALDOB", "CYP3A4", "CYP2C9", "UGT1A1", "SULT1A1", "NAT2",
