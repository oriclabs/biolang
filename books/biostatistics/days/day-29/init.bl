# Base expression counts (control/normal tissue)
let named_base = [
    # Housekeeping (high, stable)
    12500, 15800, 9200, 8500, 6200, 7800, 7100, 11200,
    5600, 6900, 5200, 4800, 5500, 4200, 4900, 4600,
    4100, 6500, 8200, 7500,
