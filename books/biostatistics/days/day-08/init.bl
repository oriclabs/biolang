# Day 8: t-Tests — Data Generation
# Source: TCGA BRCA RNA-seq (cancer.gov/tcga) — fold changes from published data
#         Early Breast Cancer Trialists' Group (EBCTCG) — tamoxifen response
# Expression values as log2(TPM+1) with published tumor/normal fold changes.
# ESR1: ~10x up in ER+ tumors, ERBB2: ~8x in HER2+, MKI67: ~4x, BRCA1: ~0.5x

println("Day 8: t-Tests")
println("================")
println("Generating breast cancer expression and paired treatment data...")

mkdir("data")

# --- File 1: breast_cancer_expression.csv ---
# 5 key genes, 12 tumor + 12 matched normal samples
# log2(TPM+1) values with biological noise
# Based on TCGA BRCA matched tumor-normal RNA-seq

let expr_header = ["sample_id,tissue_type,ESR1,ERBB2,TP53,MKI67,BRCA1"]
let expr_lines = expr_header

# Normal tissue base values (log2 TPM+1):
# ESR1 ~3.5, ERBB2 ~4.2, TP53 ~5.8, MKI67 ~2.5, BRCA1 ~4.8
# Fold changes: ESR1 10x (log2 +3.32), ERBB2 8x (+3.0), TP53 1.5x (+0.58),
#               MKI67 4x (+2.0), BRCA1 0.5x (-1.0)

# Normal samples — realistic variation around base expression
let normal_esr1  = [3.2, 3.8, 3.5, 3.1, 3.9, 3.4, 3.7, 3.3, 3.6, 3.0, 3.8, 3.5]
let normal_erbb2 = [4.0, 4.5, 4.2, 3.8, 4.4, 4.1, 4.3, 3.9, 4.2, 4.6, 4.0, 4.3]
let normal_tp53  = [5.5, 6.1, 5.8, 5.4, 6.0, 5.7, 5.9, 5.3, 5.8, 6.2, 5.6, 5.9]
let normal_mki67 = [2.2, 2.8, 2.5, 2.1, 2.7, 2.4, 2.6, 2.0, 2.5, 2.9, 2.3, 2.6]
let normal_brca1 = [4.5, 5.1, 4.8, 4.4, 5.0, 4.7, 4.9, 4.3, 4.8, 5.2, 4.6, 4.9]

# Tumor samples — shifted by fold change + additional noise
let tumor_esr1  = [6.8, 7.2, 6.5, 7.5, 6.2, 7.0, 6.9, 7.3, 6.4, 7.1, 6.7, 7.4]
let tumor_erbb2 = [7.2, 7.8, 7.0, 7.5, 6.8, 7.4, 7.1, 7.6, 6.9, 7.3, 7.5, 7.7]
let tumor_tp53  = [6.2, 6.5, 6.0, 6.8, 5.8, 6.4, 6.1, 6.6, 5.9, 6.3, 6.7, 6.5]
let tumor_mki67 = [4.5, 4.8, 4.2, 5.1, 4.0, 4.7, 4.4, 4.9, 4.1, 4.6, 5.0, 4.8]
let tumor_brca1 = [3.8, 3.5, 4.0, 3.2, 3.9, 3.6, 3.4, 4.1, 3.7, 3.3, 3.5, 3.8]

for i in range(0, 12) {
    let sid = f"TCGA_N{i + 1:02}"
    expr_lines = append(expr_lines,
        f"{sid},normal,{normal_esr1[i]},{normal_erbb2[i]},{normal_tp53[i]},{normal_mki67[i]},{normal_brca1[i]}")
}
for i in range(0, 12) {
    let sid = f"TCGA_T{i + 1:02}"
    expr_lines = append(expr_lines,
        f"{sid},tumor,{tumor_esr1[i]},{tumor_erbb2[i]},{tumor_tp53[i]},{tumor_mki67[i]},{tumor_brca1[i]}")
}
write_lines(expr_lines, "data/breast_cancer_expression.csv")

# --- File 2: treatment_paired.csv ---
# Paired ESR1 expression before/after 3 months tamoxifen treatment
# 15 ER+ breast cancer patients
# Source: EBCTCG meta-analysis + Dowsett et al. 2005 Clin Cancer Res
# Tamoxifen reduces ESR1 transcription by ~40% on average (published)
# Before: ~6.5-8.5 log2(TPM+1), After: ~60% of before

let paired_header = ["patient_id,before,after"]
let paired_lines = paired_header

# Before treatment ESR1 expression (log2 TPM+1)
let before_vals = [7.8, 8.2, 7.5, 8.5, 7.2, 7.9, 8.1, 7.4, 8.3, 7.6, 8.0, 7.3, 8.4, 7.7, 8.1]

# After treatment: ~60% of before (40% reduction) with individual response variation
# Some patients respond well (50% reduction), others less (30% reduction)
let after_vals = [4.5, 5.2, 4.8, 4.2, 4.9, 4.6, 5.5, 4.1, 5.0, 4.4, 5.3, 4.7, 4.3, 5.1, 4.8]

for i in range(0, 15) {
    paired_lines = append(paired_lines, f"PT_{i + 1:03},{before_vals[i]},{after_vals[i]}")
}
write_lines(paired_lines, "data/treatment_paired.csv")

println("Generated 2 files in data/")
println("  data/breast_cancer_expression.csv — 24 samples, 5 genes (TCGA BRCA)")
println("  data/treatment_paired.csv         — 15 patients, tamoxifen response")
