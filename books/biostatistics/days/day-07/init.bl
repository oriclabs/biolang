# Day 7: Hypothesis Testing — Data Generation
# Source: Janelidze et al. 2020 JAMA Neurology 77(9):1085-1091
# Plasma p-tau181 in Alzheimer's disease vs cognitively normal controls.
# AD group: mean ~24.5 pg/mL, SD ~8.2 (published values from BioFINDER-2)
# Control group: mean ~11.8 pg/mL, SD ~4.5

println("Day 7: Hypothesis Testing")
println("==========================")
println("Generating Alzheimer's biomarker and null simulation data...")

mkdir("data")

# --- File 1: biomarker_alzheimer.csv ---
# Plasma p-tau181 levels (pg/mL)
# 50 Alzheimer's patients + 50 cognitively normal controls
# Values based on Janelidze et al. 2020 BioFINDER-2 cohort

let bio_header = ["patient_id,group,p_tau181_pgml"]
let bio_lines = bio_header

# AD patients: mean ~24.5, SD ~8.2 (hardcoded with realistic scatter)
let ad_values = [
    28.3, 22.1, 35.2, 18.5, 26.8, 31.4, 20.2, 24.5, 29.1, 15.8,
    33.5, 21.8, 27.2, 38.1, 19.5, 25.8, 30.5, 16.2, 23.8, 34.2,
    26.5, 22.8, 29.8, 17.5, 32.1, 24.2, 28.5, 20.8, 35.8, 21.2,
    27.5, 23.5, 31.8, 18.8, 26.2, 33.8, 19.8, 25.2, 29.5, 16.5,
    34.5, 22.5, 28.8, 37.2, 20.5, 24.8, 30.2, 17.2, 32.5, 23.2
]

# Controls: mean ~11.8, SD ~4.5
let ctrl_values = [
    10.2, 13.5, 8.8, 12.1, 15.2, 9.5, 11.8, 14.5, 7.8, 13.2,
    10.8, 16.5, 9.2, 12.5, 11.2, 8.2, 14.8, 10.5, 13.8, 7.5,
    11.5, 15.8, 9.8, 12.8, 10.2, 8.5, 14.2, 11.8, 13.5, 7.2,
    12.2, 16.2, 9.5, 11.2, 10.8, 8.8, 15.5, 10.2, 13.2, 7.8,
    11.8, 14.8, 9.2, 12.5, 10.5, 8.2, 15.2, 11.5, 13.8, 6.8
]

for i in range(0, 50) {
    bio_lines = append(bio_lines, f"AD_{i + 1:03},alzheimer,{ad_values[i]}")
}
for i in range(0, 50) {
    bio_lines = append(bio_lines, f"CN_{i + 1:03},control,{ctrl_values[i]}")
}
write_lines(bio_lines, "data/biomarker_alzheimer.csv")

# --- File 2: null_simulation.csv ---
# 1000 z-statistics generated under H0 (standard normal distribution)
# For visualizing the null distribution and understanding p-values
# Hardcoded values following N(0,1) — pre-sorted for easy binning

let null_header = ["index,z_statistic"]
let null_lines = null_header

# 1000 values approximating standard normal quantiles
# z = qnorm((i - 0.5) / 1000) for i = 1..1000
# Hardcoded in blocks of 50 to cover the full distribution
let z_blocks = [
    [-3.090, -2.878, -2.748, -2.652, -2.576, -2.512, -2.457, -2.409, -2.366, -2.326],
    [-2.290, -2.257, -2.226, -2.197, -2.170, -2.144, -2.120, -2.097, -2.075, -2.054],
    [-2.034, -2.014, -1.995, -1.977, -1.960, -1.943, -1.927, -1.911, -1.896, -1.881],
    [-1.866, -1.852, -1.838, -1.825, -1.812, -1.799, -1.787, -1.774, -1.762, -1.751],
    [-1.739, -1.728, -1.717, -1.706, -1.695, -1.685, -1.675, -1.665, -1.655, -1.645],
    [-1.636, -1.626, -1.617, -1.607, -1.598, -1.589, -1.580, -1.572, -1.563, -1.555],
    [-1.546, -1.538, -1.530, -1.522, -1.514, -1.506, -1.498, -1.490, -1.483, -1.476],
    [-1.468, -1.461, -1.454, -1.447, -1.440, -1.433, -1.426, -1.419, -1.412, -1.405],
    [-1.399, -1.392, -1.386, -1.379, -1.373, -1.366, -1.360, -1.354, -1.348, -1.341],
    [-1.335, -1.329, -1.323, -1.317, -1.311, -1.305, -1.299, -1.293, -1.288, -1.282]
]

# Write the first 100 (lower tail)
for b in range(0, 10) {
    for j in range(0, 10) {
        let idx = b * 10 + j + 1
        null_lines = append(null_lines, f"{idx},{z_blocks[b][j]}")
    }
}

# Middle 800 values: linearly spaced from -1.276 to +1.276
for i in range(0, 800) {
    let z = round(-1.276 + i * 2.552 / 799.0, 3)
    null_lines = append(null_lines, f"{i + 101},{z}")
}

# Upper tail 100: mirror of lower tail
for b in range(0, 10) {
    for j in range(0, 10) {
        let idx = 900 + b * 10 + j + 1
        let z = round(-1.0 * z_blocks[9 - b][9 - j], 3)
        null_lines = append(null_lines, f"{idx},{z}")
    }
}
write_lines(null_lines, "data/null_simulation.csv")

println("Generated 2 files in data/")
println("  data/biomarker_alzheimer.csv — 100 p-tau181 values (Janelidze 2020)")
println("  data/null_simulation.csv     — 1000 z-statistics under H0")
