# ── Build the full GWAS summary stats ──
println("Generating 500,000 SNP summary statistics...")

let header = "snp_id,chr,position,ref,alt,maf,beta,se,p_value,odds_ratio,true_association"
let lines = [header]

# Write 50 true associations first
for locus in true_loci {
    lines = append(lines, locus + ",1")
}
println("  50 true T2D loci written (from Mahajan et al. 2018)")

# ── Generate 499,950 null SNPs programmatically ──
println("  Generating 499,950 null SNPs...")

let ref_alleles = ["A", "C", "G", "T"]
let alt_alleles = ["T", "G", "A", "C"]

for i in range(0, 499950) {
    # Deterministic pseudo-random values
    let seed1 = (i * 2654435761 + 12345) % 2147483647
    let seed2 = (i * 1664525 + 1013904223) % 2147483647
    let seed3 = (i * 214013 + 2531011) % 2147483647
    let seed4 = (i * 1103515245 + 54321) % 2147483647

    let chr = (seed1 % 22) + 1
    let pos = (seed2 % 200000000) + 1000000
    let ref_idx = seed3 % 4
    let alt_idx = (ref_idx + 1 + seed4 % 3) % 4

    let maf = round(0.01 + (seed1 % 4900) / 10000.0, 4)

    # Null SNP: p-value from uniform(0,1), small effect
    let p_raw = (seed2 % 10000) / 10000.0
    if p_raw < 0.0001 then p_raw = 0.0001
    let p_val = round(p_raw, 6)

    # Small random beta centered on 0
    let beta_raw = ((seed3 % 10000) / 10000.0 - 0.5) * 0.1
    let beta = round(beta_raw, 5)
    let se = round(abs(beta) / 1.5 + 0.01 + (seed4 % 300) / 10000.0, 5)
    let or_val = round(2.71828 ** beta, 4)

    let snp_id = f"rs{1000000 + i}"
    let ref_al = ref_alleles[ref_idx]
    let alt_al = alt_alleles[alt_idx]

    lines = append(lines, f"{snp_id},{chr},{pos},{ref_al},{alt_al},{maf},{beta},{se},{p_val},{or_val},0")
}

write_lines(lines, "data/gwas_summary.csv")

println("")
println("Created data/sample_info.csv")
println("  Study metadata: 5,000 cases + 5,000 controls, European ancestry")
println("Created data/gwas_summary.csv")
println("  500,000 SNPs total")
println("  50 true T2D associations from Mahajan et al. 2018 / DIAGRAM")
println("  Loci include: TCF7L2, PPARG, KCNJ11, FTO, SLC30A8, CDKN2A/B, etc.")
println("  499,950 null SNPs with uniform p-value distribution")
