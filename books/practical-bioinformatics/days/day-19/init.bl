# ── Expression matrix: GTEx-based tissue profiles ────────────────────
# 40 genes x 8 tissues, values are log2(TPM+1) representative of GTEx v8
# Tissues: Liver, Brain_Cortex, Heart, Skeletal_Muscle, Lung, Kidney, Pancreas, Blood
# Patterns: tissue-specific genes + housekeeping + mixed expression

let expr_header = "gene,Liver,Brain_Cortex,Heart,Skeletal_Muscle,Lung,Kidney,Pancreas,Blood"
let expr_rows = [
    # Liver-specific genes
    "ALB,14.2,0.3,0.2,0.1,0.4,0.5,0.2,0.3",
