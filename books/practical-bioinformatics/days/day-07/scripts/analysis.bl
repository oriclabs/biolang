# Day 7: Bioinformatics File Formats — Multi-Format Analysis
# Run: bl run scripts/analysis.bl
# Requires: data/ files (generated by init.bl)

print("=" * 60)
print("Day 7: Bioinformatics File Formats")
print("=" * 60)

# ============================================================
# 1. FASTA — REFERENCE SEQUENCES
# ============================================================
print("")
print("--- 1. FASTA: Reference Sequences ---")

let seqs = read_fasta("data/sequences.fasta")
print(f"Sequences: {len(seqs)}")

for s in seqs {
    print(f"  {s.id}: {len(s.seq)} bp, GC={round(gc_content(s.seq) * 100, 1)}%")
}

let stats = fasta_stats("data/sequences.fasta")
print(f"Total bases: {stats.total_bases}")
print(f"Mean length: {round(stats.mean_length, 1)}")

# Streaming total
let total_bases = fasta("data/sequences.fasta")
    |> map(|s| len(s.seq))
    |> reduce(|a, b| a + b)
print(f"Total bases (streaming): {total_bases}")

# ============================================================
# 2. VCF — VARIANT CALLS
# ============================================================
print("")
print("--- 2. VCF: Variant Calls ---")

let variants = read_vcf("data/variants.vcf")
print(f"Total variants: {len(variants)}")

let v = first(variants)
print(f"First variant: {v.chrom}:{v.pos} {v.ref}>{v.alt}")

# Filter to passing
let passed = variants |> filter(|v| v.filter == "PASS")
print(f"PASS variants: {len(passed)}")

# Classify variant types
let snps = variants |> filter(|v| len(v.ref) == 1 and len(v.alt) == 1)
let indels = variants |> filter(|v| len(v.ref) != len(v.alt))
print(f"SNPs: {len(snps)}")
print(f"Indels: {len(indels)}")

# Count by chromosome
let by_chrom = passed
    |> to_table()
    |> group_by("chrom")
    |> summarize(|chrom, rows| {chrom: chrom, count: len(rows)})
print(by_chrom)

# Streaming SNP count
let snp_stream = vcf("data/variants.vcf")
    |> filter(|v| len(v.ref) == 1 and len(v.alt) == 1)
    |> count()
print(f"SNPs (streaming): {snp_stream}")

# ============================================================
# 3. BED — GENOMIC REGIONS
# ============================================================
print("")
print("--- 3. BED: Genomic Regions ---")

let regions = read_bed("data/regions.bed")
print(f"Regions: {len(regions)}")

let total_covered = regions
    |> map(|r| r.end - r.start)
    |> reduce(|a, b| a + b)
print(f"Total bases covered: {total_covered}")

let chr17 = regions |> filter(|r| r.chrom == "chr17")
print(f"Chr17 regions: {len(chr17)}")

let sizes = regions |> map(|r| r.end - r.start)
print(f"Region sizes:")
print(f"  Min: {min(sizes)}")
print(f"  Max: {max(sizes)}")
print(f"  Mean: {round(mean(sizes), 1)}")

# ============================================================
# 4. GFF — GENE ANNOTATIONS
# ============================================================
print("")
print("--- 4. GFF: Gene Annotations ---")

let features = read_gff("data/annotations.gff")
print(f"Features: {len(features)}")

let genes = features |> filter(|f| f.type == "gene")
let exons = features |> filter(|f| f.type == "exon")
let cds = features |> filter(|f| f.type == "CDS")
print(f"Genes: {len(genes)}")
print(f"Exons: {len(exons)}")
print(f"CDS:   {len(cds)}")

# Gene names
let gene_names = genes |> map(|f| f.attributes.gene_name)
print(f"Gene names: {gene_names}")

# Feature type counts
let type_counts = features
    |> to_table()
    |> group_by("type")
    |> summarize(|feat_type, rows| {type: feat_type, count: len(rows)})
print(type_counts)

# Streaming exon count
let exon_stream = gff("data/annotations.gff")
    |> filter(|f| f.type == "exon")
    |> count()
print(f"Exons (streaming): {exon_stream}")

# ============================================================
# 5. BAM — ALIGNMENTS
# ============================================================
print("")
print("--- 5. BAM: Alignments ---")

let alignments = read_bam("data/alignments.bam")
print(f"Total alignments: {len(alignments)}")

let mapped = alignments |> filter(|r| r.is_mapped)
let unmapped = alignments |> filter(|r| not r.is_mapped)
print(f"Mapped: {len(mapped)}")
print(f"Unmapped: {len(unmapped)}")

let mapqs = mapped |> map(|r| r.mapq)
print(f"Mean MAPQ: {round(mean(mapqs), 1)}")
print(f"High quality (MAPQ >= 30): {len(mapqs |> filter(|q| q >= 30))}")

# Streaming mapped count
let mapped_stream = bam("data/alignments.bam")
    |> filter(|r| r.is_mapped)
    |> count()
print(f"Mapped reads (streaming): {mapped_stream}")

# ============================================================
# 6. FORMAT CONVERSIONS
# ============================================================
print("")
print("--- 6. Format Conversions ---")

# VCF to BED (1-based to 0-based)
let vcf_beds = variants |> map(|v| {
    chrom: v.chrom,
    start: v.pos - 1,
    end: v.pos - 1 + len(v.ref)
})
print(f"VCF -> BED: {len(vcf_beds)} variant intervals")
print(f"  First: {first(vcf_beds).chrom}:{first(vcf_beds).start}-{first(vcf_beds).end}")

# GFF genes to BED (1-based inclusive to 0-based half-open)
let gene_beds = genes |> map(|f| {
    chrom: f.seqid,
    start: f.start - 1,
    end: f.end,
    name: f.attributes.gene_name
})
print(f"GFF -> BED: {len(gene_beds)} gene regions")

# ============================================================
# 7. WRITING OUTPUT
# ============================================================
print("")
print("--- 7. Writing Output ---")

# Write FASTA
let out_seqs = [
    {id: "seq1", seq: dna"ATCGATCG"},
    {id: "seq2", seq: dna"GCGCGCGC"},
]
write_fasta(out_seqs, "results/output.fasta")
print("Wrote 2 sequences to results/output.fasta")

# Write BED
let out_regions = [
    {chrom: "chr1", start: 100, end: 200},
    {chrom: "chr1", start: 300, end: 400},
]
write_bed(out_regions, "results/output.bed")
print(f"Wrote {len(out_regions)} regions to results/output.bed")

# Write CSV
let results = [
    {gene: "BRCA1", pval: 0.001, chrom: "chr17"},
    {gene: "TP53", pval: 0.05, chrom: "chr17"},
    {gene: "EGFR", pval: 0.003, chrom: "chr7"},
] |> to_table()
write_csv(results, "results/output.csv")
print(f"Wrote {nrow(results)} rows to results/output.csv")

# ============================================================
# 8. SUMMARY TABLE
# ============================================================
print("")
print("--- 8. Summary ---")

let summary = [
    {metric: "Reference sequences", value: len(seqs)},
    {metric: "Total ref bases", value: stats.total_bases},
    {metric: "Total variants", value: len(variants)},
    {metric: "PASS variants", value: len(passed)},
    {metric: "SNPs", value: len(snps)},
    {metric: "Indels", value: len(indels)},
    {metric: "BED regions", value: len(regions)},
    {metric: "Target bases", value: total_covered},
    {metric: "GFF features", value: len(features)},
    {metric: "Genes", value: len(genes)},
    {metric: "Total alignments", value: len(alignments)},
    {metric: "Mapped reads", value: len(mapped)},
] |> to_table()
print(summary)

print("")
print("=" * 60)
print("Day 7 complete! You can now read every major bio format.")
print("=" * 60)
