    "",
    ">MYC_CDS NM_002467.6 Homo sapiens MYC proto-oncogene, partial CDS [1-450]",
    "",
    ">RB1_CDS NM_000321.3 Homo sapiens RB1, partial CDS [1-420]",
    "",
    ">APC_CDS NM_000038.6 Homo sapiens APC, partial CDS [1-420]",
    "",
    ">VHL_CDS NM_000551.4 Homo sapiens VHL, complete CDS",
    "ATGCCCCGGAGGGCGGAGAACTGGGACGAGGCCGAGGTAGGCGCGGAGGAGGCAGGCGTCGAAGACTACGGAGGTCGACTCGGGAGCGCGCACGCAGCTCCGCCAGCGTCGTCGTCCTCCCCGGCGCACTCGGCCCAGGCCTCGGATCGCAGATCTTCCTCTCCTGACCTTAGGATGTCACCTTTACCCAGACTACCGAGCGCGCGCGAAGACTACGGAGGTCGACTCGGGAGCGCGCACGCAGCTATTTCCCAGATCTTCCTCTCCTGACCTTAGGATGTCAC",
    ">PTEN_CDS NM_000314.8 Homo sapiens PTEN, partial CDS [1-450]",
