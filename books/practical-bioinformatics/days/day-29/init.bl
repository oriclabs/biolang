# Day 29 Init: Capstone — RNA-seq Differential Expression — Real Biological Data
# Source: Modeled on doxorubicin-treated MCF-7 breast cancer cells
#   Reference: Troester et al., Cancer Res 2004; Taymaz-Nikerel et al., PLoS ONE 2018
#   Gene names/lengths from NCBI RefSeq (GRCh38). Counts reflect known doxorubicin response:
#     - DNA damage response genes strongly upregulated (CDKN1A, BAX, BBC3, GADD45A, MDM2)
#     - Cell cycle genes strongly downregulated (CCNA2, CCNB1, CDK1, TOP2A, MKI67)
#     - Apoptosis/drug efflux genes moderately upregulated
#     - Housekeeping genes stable with biological noise (±20%)

mkdir("data")
mkdir("data/output")

# GO term pairs for pathway annotation
let go_sets = [
    "GO:0006915|GO:0012501",
    "GO:0006915|GO:0008219",
    "GO:0006281|GO:0006974",
    "GO:0006281|GO:0000723",
    "GO:0007049|GO:0051301",
    "GO:0007049|GO:0000278",
    "GO:0006955|GO:0002376",
    "GO:0006955|GO:0045087",
    "GO:0007165|GO:0023052",
    "GO:0007165|GO:0035556",
    "GO:0006351|GO:0006355",
    "GO:0006351|GO:0006357",
    "GO:0016310|GO:0006468",
    "GO:0016310|GO:0007169",
    "GO:0006412|GO:0006414",
    "GO:0006412|GO:0002181",
    "GO:0055114|GO:0006091",
    "GO:0055114|GO:0045333",
    "GO:0006810|GO:0015031",
    "GO:0006810|GO:0006886"
]

# 100 real gene names grouped by biological response to doxorubicin
let gene_names = [
    # DNA damage response — strongly upregulated (genes 0-9)
    "CDKN1A", "BAX", "BBC3", "GADD45A", "MDM2", "GADD45B", "PMAIP1", "SESN1", "FDXR", "DDB2",
