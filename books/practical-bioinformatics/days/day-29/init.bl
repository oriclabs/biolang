    "AKT1", "MTOR", "PIK3CA", "MAPK1", "MAPK3",
    # Transcription factors — variable (genes 85-89)
    "MYC", "E2F1", "FOXO3", "JUN", "FOS",
    # Housekeeping — stable (genes 90-99)
    "GAPDH", "ACTB", "B2M", "HPRT1", "TBP", "RPLP0", "GUSB", "PPIA", "YWHAZ", "SDHA"
