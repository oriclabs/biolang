    "CTNNB1,ENSG00000168036,3,41194741,41260096,+,Catenin beta-1; WNT signaling effector; hepatocellular carcinoma"
]

let gene_lines = [gene_header] + gene_rows
write_lines(gene_lines, "data/gene_list.csv")
print(f"  Created data/gene_list.csv ({len(gene_rows)} cancer driver genes)")

