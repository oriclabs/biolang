    "VHL,ENSG00000134086,3,10141633,10153669,+,Von Hippel-Lindau tumor suppressor; clear cell renal carcinoma",
    "IDH1,ENSG00000138413,2,208236227,208266074,−,Isocitrate dehydrogenase 1; glioma and AML driver",
    "ALK,ENSG00000171094,2,29192774,29921566,−,ALK receptor tyrosine kinase; lung cancer fusion partner",
    "JAK2,ENSG00000096968,9,4985245,5128183,+,Janus kinase 2; myeloproliferative neoplasm driver (V617F)",
