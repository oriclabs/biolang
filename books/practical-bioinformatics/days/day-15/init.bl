# Day 15: Publication-Quality Visualization
# Generates data/de_results.csv (50 genes with DE stats)
# and data/sample.fastq (25 reads from E. coli K-12 lacZ)
#
# Data sources:
#   DE results: Based on TCGA Breast Invasive Carcinoma (BRCA) RNA-seq
#     analysis, basal vs luminal A subtype. Gene names, direction of change,
#     and approximate effect sizes from Cancer Genome Atlas Network,
#     Nature 490:61-70, 2012. Values representative, not verbatim.
#   FASTQ reads: 150 bp fragments from E. coli K-12 substr. MG1655 lacZ
#     gene (GenBank U00096.3, complement 360,483..363,558). Sequences are
#     real subsequences; quality scores simulate typical Illumina HiSeq 2500
#     output (Q30-Q40 early, declining toward 3' end).

print("Setting up Day 15: Publication-Quality Visualization")
print("Generating data files...")

# Create output directories
mkdir("data")
mkdir("figures")
mkdir("results")

# ── DE results: 50 genes, TCGA BRCA basal-vs-luminal-A representative ──
# Columns: gene, log2fc, baseMean, pvalue, padj
# Positive log2fc = upregulated in basal subtype

let header = "gene,log2fc,baseMean,pvalue,padj"
let rows = [
    # Strongly upregulated in basal subtype (proliferation, EMT, basal markers)
    "KRT5,4.82,3240,1.2e-42,8.5e-40",
    "KRT14,4.35,2870,3.7e-38,1.9e-35",
    "KRT17,3.91,2150,8.4e-33,3.1e-30",
    "EGFR,3.12,2340,5.0e-28,1.4e-25",
    "MYC,2.89,1980,2.1e-24,4.7e-22",
    "FOXC1,2.67,1120,6.3e-21,1.1e-18",
    "CDK6,2.45,1530,4.8e-19,7.3e-17",
    "MKI67,2.31,1870,1.5e-17,1.9e-15",
    "CCNE1,2.18,960,9.2e-16,1.0e-13",
    "AURKA,2.04,1250,3.6e-14,3.5e-12",
    "VIM,1.89,1680,7.1e-13,6.1e-11",
    "SNAI2,1.72,840,2.4e-11,1.8e-09",
    "SOX9,1.55,720,5.8e-10,3.9e-08",
    "CDK4,1.41,1310,8.3e-09,5.0e-07",
    "BIRC5,1.28,1050,4.1e-08,2.2e-06",
    # Strongly downregulated in basal (luminal markers, ER signaling)
    "ESR1,-5.24,4680,2.5e-58,5.1e-55",
    "GATA3,-4.67,3920,1.8e-50,2.4e-47",
    "FOXA1,-4.12,3150,4.2e-44,4.0e-41",
    "ERBB2,-3.58,2510,9.7e-37,7.1e-34",
    "PGR,-3.21,1840,3.3e-31,1.9e-28",
    "BCL2,-2.85,1560,7.6e-27,3.7e-24",
    "XBP1,-2.52,2080,1.4e-22,5.6e-20",
    "TFF1,-2.34,1290,6.8e-19,2.3e-16",
    "TFF3,-2.18,970,2.9e-16,8.6e-14",
    "CCND1,-1.95,2340,8.5e-14,4.4e-11",
    "MUC1,-1.78,1620,1.7e-11,7.8e-09",
    "AR,-1.61,1150,5.3e-10,2.1e-07",
    "ERBB3,-1.45,880,9.1e-08,3.2e-05",
    "SPDEF,-1.32,640,4.6e-07,0.00015",
    "AGR2,-1.19,1080,7.2e-06,0.002",
    # Moderate changes (borderline significant)
    "TP53,1.12,1450,0.00003,0.0068",
    "PIK3CA,-0.95,1820,0.00012,0.022",
    "PTEN,-0.88,2100,0.00035,0.052",
    "STAT3,0.82,920,0.0008,0.098",
    "JAK2,-0.75,680,0.002,0.19",
    "NOTCH1,0.68,540,0.005,0.35",
    "AKT1,-0.62,1350,0.008,0.42",
    "BRCA1,0.55,760,0.015,0.52",
    # Not significant (housekeeping / stable genes)
    "GAPDH,0.08,8920,0.72,0.95",
    "ACTB,-0.05,7650,0.84,0.97",
    "B2M,0.11,6340,0.58,0.91",
    "RPL13A,-0.03,5120,0.91,0.99",
    "HPRT1,0.06,3870,0.79,0.96",
    "TBP,-0.09,2950,0.65,0.93",
    "PPIA,0.04,4580,0.88,0.98",
    "RPLP0,-0.07,6210,0.71,0.94",
    "SDHA,0.10,3140,0.62,0.92",
    "YWHAZ,-0.02,4890,0.93,0.99",
    "UBC,0.13,5730,0.51,0.89",
    "HMBS,-0.06,2680,0.76,0.95"
]

let content = header
for row in rows {
    content = content + "\n" + row
}
write(content, "data/de_results.csv")
print("  Created data/de_results.csv (50 genes, TCGA BRCA basal vs luminal A)")

