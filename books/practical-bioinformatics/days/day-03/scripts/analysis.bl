# Day 3: Biology Crash Course for Developers
# All biology explorations in one script
# Run: bl run scripts/analysis.bl

print("=" * 60)
print("Day 3: Biology Crash Course for Developers")
print("=" * 60)

# ── Section 1: DNA — The Source Code ─────────────────────────

print("")
print("--- DNA: The Source Code ---")

let coding = dna"ATGCGATCG"
let comp = complement(coding)
let rc = reverse_complement(coding)
print(f"Coding:     5'-{coding}-3'")
print(f"Complement: 3'-{comp}-5'")
print(f"RevComp:    5'-{rc}-3'")

# ── Section 2: The Central Dogma ─────────────────────────────

print("")
print("--- The Central Dogma: DNA -> RNA -> Protein ---")

let seq = dna"ATGGCTAACTGA"
let rna = transcribe(seq)
let protein = translate(seq)
print(f"DNA:     {seq}")
print(f"RNA:     {rna}")
print(f"Protein: {protein}")
print("M = Methionine (start), A = Alanine, N = Asparagine")

# ── Section 3: Codon Usage ───────────────────────────────────

print("")
print("--- Codon Usage ---")

let gene = dna"ATGGCTGCTTCTGATTGA"
let usage = codon_usage(gene)
print(f"Sequence: {gene}")
print(f"Usage:    {usage}")

# ── Section 4: Mutations ────────────────────────────────────

print("")
print("--- Mutations: Bugs in the Code ---")

let normal = dna"ATGGCTAACTGA"
let mutant = dna"ATGGCTGACTGA"   # A->G at position 7

let normal_protein = normal |> translate()
let mutant_protein = mutant |> translate()

print(f"Normal DNA:     {normal}")
print(f"Mutant DNA:     {mutant}")
print(f"Normal protein: {normal_protein}")
print(f"Mutant protein: {mutant_protein}")
print(f"Changed:        {normal_protein != mutant_protein}")
print("One base change (A->G) changed Asparagine (N) to Aspartate (D)")

# ── Section 5: Wobble Position Experiment ────────────────────

print("")
print("--- Wobble Position Experiment ---")
print("Mutating each position of codon GCT (Alanine):")

let original = dna"ATGGCTTGA"
let mut_pos1 = dna"ATGTCTTGA"   # G->T at codon position 1
let mut_pos2 = dna"ATGGATTGA"   # C->A at codon position 2
let mut_pos3 = dna"ATGGCATGA"   # T->A at codon position 3

print(f"Original (GCT): {translate(original)}")
print(f"Pos1 mut (TCT): {translate(mut_pos1)}")
print(f"Pos2 mut (GAT): {translate(mut_pos2)}")
print(f"Pos3 mut (GCA): {translate(mut_pos3)}")
print("Position 3 (wobble) is most tolerant — GCA still encodes Alanine")

# ── Section 6: Genomic Intervals ────────────────────────────

print("")
print("--- Genomic Intervals ---")

let brca1_location = interval("chr17", 43044295, 43125483)
let tp53_location = interval("chr17", 7668402, 7687550)

print(f"BRCA1: {brca1_location}")
print(f"TP53:  {tp53_location}")
print(f"Same chromosome: {brca1_location.chrom == tp53_location.chrom}")

# Overlap check for two chromosome 7 genes
let egfr = interval("chr7", 55019017, 55211628)
let braf = interval("chr7", 140719327, 140924929)

let same_chrom = egfr.chrom == braf.chrom
let overlaps = same_chrom and egfr.start < braf.end and braf.start < egfr.end

print(f"EGFR: {egfr}")
print(f"BRAF: {braf}")
print(f"Same chromosome: {same_chrom}")
print(f"Overlap: {overlaps}")

# ── Section 7: TP53 — The Guardian ──────────────────────────

print("")
print("--- TP53: The Guardian of the Genome ---")

let normal_tp53 = dna"ATGGAGGAGCCGCAGTCAGATCCTAGC"
let tp53_protein = normal_tp53 |> translate()
print(f"TP53 coding start: {normal_tp53}")
print(f"Protein begins:    {tp53_protein}")
print(f"GC content:        {gc_content(normal_tp53)}")
print("TP53 is mutated in >50% of all human cancers")

# ── Section 8: Exercise 1 — Hand Translation ────────────────

print("")
print("--- Exercise 1: Hand Translation ---")

let ex1 = dna"ATGAAAGCTTGA"
print(f"Sequence: {ex1}")
print(f"Codons:   ATG | AAA | GCT | TGA")
print(f"Expected: M     K     A    Stop")
print(f"Result:   {translate(ex1)}")

print("")
print("=" * 60)
print("Day 3 complete!")
print("=" * 60)
