    "chrX\t5678901\t.\tC\tA\t11.8\tLowQual\tDP=5;AF=0.40;MQ=28;CLNSIG=.;GENEINFO=.\tGT:DP:GQ\t0/1:5:11",
    # Indels for variety
    "chr17\t7579472\t.\tGC\tG\t62.8\tPASS\tDP=31;AF=0.48;MQ=57;CLNSIG=Uncertain_significance;GENEINFO=TP53\tGT:DP:GQ\t0/1:31:62",
    "chr5\t112841060\t.\tC\tCAA\t55.3\tPASS\tDP=27;AF=0.44;MQ=55;CLNSIG=Uncertain_significance;GENEINFO=APC\tGT:DP:GQ\t0/1:27:55"
]

# Write VCF file
let vcf_content = header
let i = 0
while i < len(rows) {
    vcf_content = vcf_content + "\n" + rows[i]
    i = i + 1
}
vcf_content = vcf_content + "\n"

let vcf_lines = [vcf_content]
write_lines(vcf_lines, "data/variants.vcf")

print(f"Generated data/variants.vcf with {len(rows)} variants")
print("  Genes: TP53, BRCA1, BRCA2, KRAS, BRAF, EGFR, PIK3CA, IDH1, JAK2, PTEN, RB1, APC, VHL, HBB")
print("  Includes pathogenic (ClinVar), benign, and uncertain significance variants")
print("  Variant types: SNPs, insertions, deletions")
print("  Filters: PASS, LowQual, LowDP")
print("  Quality range: 9.7 to 99.0")
print("")
print("Day 12 is ready.")
print("Run: bl run scripts/analysis.bl")
