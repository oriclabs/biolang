    # PTEN variants (chr10) — Cowden syndrome
    "chr10\t87933147\trs121909218\tC\tT\t93.9\tPASS\tDP=49;AF=0.48;MQ=60;CLNSIG=Pathogenic;GENEINFO=PTEN\tGT:DP:GQ\t0/1:49:93",
    "chr10\t87952118\trs587776667\tC\tCA\t86.4\tPASS\tDP=37;AF=0.46;MQ=58;CLNSIG=Pathogenic;GENEINFO=PTEN\tGT:DP:GQ\t0/1:37:86",
    # RB1 variant (chr13) — retinoblastoma
    "chr13\t48367556\trs121913300\tC\tT\t91.5\tPASS\tDP=46;AF=0.49;MQ=60;CLNSIG=Pathogenic;GENEINFO=RB1\tGT:DP:GQ\t0/1:46:91",
    # APC variant (chr5) — familial adenomatous polyposis
    "chr5\t112839514\trs121913332\tCA\tC\t90.8\tPASS\tDP=45;AF=0.47;MQ=60;CLNSIG=Pathogenic;GENEINFO=APC\tGT:DP:GQ\t0/1:45:90",
    # VHL variant (chr3) — clear cell renal carcinoma
    "chr3\t10149920\trs28940313\tC\tT\t89.6\tPASS\tDP=43;AF=0.50;MQ=59;CLNSIG=Pathogenic;GENEINFO=VHL\tGT:DP:GQ\t0/1:43:89",
    # Benign/common variants for contrast
    "chr1\t14907\trs6682375\tA\tG\t45.3\tPASS\tDP=32;AF=0.50;MQ=60;CLNSIG=Benign;GENEINFO=WASH7P\tGT:DP:GQ\t0/1:32:45",
    "chr1\t69511\trs75062661\tA\tG\t78.6\tPASS\tDP=38;AF=0.48;MQ=60;CLNSIG=Benign;GENEINFO=OR4F5\tGT:DP:GQ\t0/1:38:78",
    "chr2\t25234373\trs1801133\tG\tA\t88.2\tPASS\tDP=44;AF=0.50;MQ=60;CLNSIG=Benign;GENEINFO=MTHFR\tGT:DP:GQ\t0/1:44:88",
    "chr7\t117199646\trs6943\tC\tT\t75.4\tPASS\tDP=35;AF=0.51;MQ=59;CLNSIG=Benign;GENEINFO=CFTR\tGT:DP:GQ\t0/1:35:75",
    "chr11\t5226774\trs334\tA\tT\t82.7\tPASS\tDP=40;AF=0.49;MQ=60;CLNSIG=Pathogenic;GENEINFO=HBB\tGT:DP:GQ\t0/1:40:82",
    # Low-quality variants (realistic sequencing artifacts)
    "chr1\t984971\t.\tG\tA\t12.5\tLowQual\tDP=5;AF=0.40;MQ=30;CLNSIG=.;GENEINFO=.\tGT:DP:GQ\t0/1:5:12",
    "chr3\t4567890\t.\tT\tA\t10.4\tLowQual\tDP=4;AF=0.25;MQ=25;CLNSIG=.;GENEINFO=.\tGT:DP:GQ\t0/1:4:10",
    "chr7\t5678901\t.\tA\tC\t9.7\tLowQual\tDP=4;AF=0.25;MQ=22;CLNSIG=.;GENEINFO=.\tGT:DP:GQ\t0/1:4:9",
