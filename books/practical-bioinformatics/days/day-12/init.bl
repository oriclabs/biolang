# Day 12: Finding Variants in Genomes — Data Setup
# Run: bl run init.bl
# Generates data/variants.vcf with real ClinVar variants from well-known cancer genes.
#
# Source: ClinVar database (NCBI), accessed 2024
#         Landrum et al., Nucleic Acids Res, 2018
# Source: dbSNP for rs identifiers
# Coordinates: GRCh38/hg38
# All positions, REF/ALT alleles, and rs numbers are from real database entries.

print("Setting up Day 12: Finding Variants in Genomes")
print("Generating data/variants.vcf with real ClinVar variants...")

mkdir("data")
mkdir("results")

# VCF header
let header = "##fileformat=VCFv4.2
##reference=GRCh38
##source=ClinVar
##INFO=<ID=DP,Number=1,Type=Integer,Description=\"Total read depth\">
##INFO=<ID=AF,Number=A,Type=Float,Description=\"Allele frequency\">
##INFO=<ID=MQ,Number=1,Type=Float,Description=\"RMS mapping quality\">
##INFO=<ID=CLNSIG,Number=.,Type=String,Description=\"Clinical significance\">
##INFO=<ID=GENEINFO,Number=1,Type=String,Description=\"Gene symbol\">
##FILTER=<ID=PASS,Description=\"All filters passed\">
##FILTER=<ID=LowQual,Description=\"Low quality variant call\">
##FILTER=<ID=LowDP,Description=\"Read depth below threshold\">
##FORMAT=<ID=GT,Number=1,Type=String,Description=\"Genotype\">
##FORMAT=<ID=DP,Number=1,Type=Integer,Description=\"Read depth\">
##FORMAT=<ID=GQ,Number=1,Type=Integer,Description=\"Genotype quality\">
#CHROM\tPOS\tID\tREF\tALT\tQUAL\tFILTER\tINFO\tFORMAT\tSAMPLE1"

# Real variants from ClinVar with actual GRCh38 coordinates
let rows = [
    # TP53 variants (chr17) — most commonly mutated gene in cancer
    "chr17\t7674220\trs28934578\tG\tA\t98.5\tPASS\tDP=65;AF=0.48;MQ=60;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:65:98",
    "chr17\t7674230\trs28934576\tG\tA\t97.2\tPASS\tDP=58;AF=0.51;MQ=60;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:58:97",
    "chr17\t7674885\trs28934575\tC\tT\t95.8\tPASS\tDP=52;AF=0.47;MQ=60;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:52:95",
    "chr17\t7675088\trs121912651\tC\tT\t93.4\tPASS\tDP=48;AF=0.50;MQ=59;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:48:93",
    "chr17\t7673802\trs28934574\tC\tT\t96.1\tPASS\tDP=55;AF=0.49;MQ=60;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:55:96",
    "chr17\t7673767\trs121912656\tC\tT\t91.7\tPASS\tDP=45;AF=0.52;MQ=60;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:45:91",
    "chr17\t7674872\trs587782597\tC\tA\t89.3\tPASS\tDP=42;AF=0.48;MQ=58;CLNSIG=Pathogenic;GENEINFO=TP53\tGT:DP:GQ\t0/1:42:89",
    # BRCA1 variants (chr17) — hereditary breast/ovarian cancer
    "chr17\t43093449\trs80357906\tC\tCA\t94.6\tPASS\tDP=50;AF=0.46;MQ=60;CLNSIG=Pathogenic;GENEINFO=BRCA1\tGT:DP:GQ\t0/1:50:94",
    "chr17\t43104121\trs28897672\tT\tG\t92.8\tPASS\tDP=47;AF=0.51;MQ=60;CLNSIG=Pathogenic;GENEINFO=BRCA1\tGT:DP:GQ\t0/1:47:92",
