# Day 6: Reading Sequencing Data — Complete QC Pipeline
# Run: bl run scripts/analysis.bl
# Requires: examples/sample.fastq (generated by init.bl)

print("=" * 60)
print("Day 6: FASTQ Quality Control Pipeline")
print("=" * 60)

# ============================================================
# 1. RAW DATA SUMMARY
# ============================================================
print("")
print("--- 1. Raw Data Summary ---")

let stats = read_stats("examples/sample.fastq")
print(f"Total reads: {stats.total_reads}")
print(f"Total bases: {stats.total_bases}")
print(f"Mean length: {round(stats.mean_length, 1)}")
print(f"Mean quality: {round(stats.mean_quality, 1)}")
print(f"GC content: {round(stats.gc_content * 100, 1)}%")

# ============================================================
# 2. PER-READ QUALITY ANALYSIS
# ============================================================
print("")
print("--- 2. Per-Read Quality Analysis ---")

let reads = read_fastq("examples/sample.fastq")
let qualities = reads |> map(|r| mean_phred(r.qual))
print(f"Quality range: {round(min(qualities), 1)} - {round(max(qualities), 1)}")
print(f"Mean quality: {round(mean(qualities), 1)}")

# Quality distribution
reads
    |> map(|r| mean_phred(r.qual))
    |> quality_plot()

# ============================================================
# 3. LENGTH DISTRIBUTION
# ============================================================
print("")
print("--- 3. Length Distribution ---")

let lengths = reads |> map(|r| len(r.seq))
print(f"Length range: {min(lengths)} - {max(lengths)}")
print(f"Mean length: {round(mean(lengths), 1)}")
let short_count = lengths |> filter(|l| l < 50) |> len()
print(f"Short reads (< 50 bp): {short_count}")

# ============================================================
# 4. STANDARD FILTERING
# ============================================================
print("")
print("--- 4. Standard Filtering ---")

let clean = reads |> filter_reads(min_length: 50, min_quality: 20)
print(f"Before: {len(reads)} reads")
print(f"After:  {len(clean)} reads")
print(f"Kept:   {round(len(clean) / len(reads) * 100, 1)}%")

# ============================================================
# 5. CUSTOM FILTERING WITH PIPES
# ============================================================
print("")
print("--- 5. Custom Filtering (length + quality + GC) ---")

let strict_clean = reads
    |> filter(|r| len(r.seq) >= 50)
    |> filter(|r| mean_phred(r.qual) >= 20)
    |> filter(|r| gc_content(r.seq) > 0.2 and gc_content(r.seq) < 0.8)
    |> collect()

print(f"After all filters: {len(strict_clean)} reads")

# ============================================================
# 6. QUALITY TRIMMING
# ============================================================
print("")
print("--- 6. Quality Trimming ---")

let trimmed = trim_quality(reads, min_quality: 20)
let original_lengths = reads |> map(|r| len(r.seq))
let trimmed_lengths = trimmed |> map(|r| len(r.seq))

print(f"Mean length before: {round(mean(original_lengths), 1)}")
print(f"Mean length after:  {round(mean(trimmed_lengths), 1)}")

# ============================================================
# 7. ADAPTER DETECTION
# ============================================================
print("")
print("--- 7. Adapter Detection ---")

let adapters = detect_adapters("examples/sample.fastq")
print(f"Detected adapters: {adapters}")

# ============================================================
# 8. K-MER ANALYSIS
# ============================================================
print("")
print("--- 8. K-mer Analysis ---")

let first_seq = first(reads).seq
let kmer_freq = kmer_count(first_seq, 5)
print(f"5-mers found in first read: {nrow(kmer_freq)}")
print("Top 10 most frequent 5-mers:")
print(kmer_freq |> head(10))

# ============================================================
# 9. CLEAN READ QUALITY SUMMARY
# ============================================================
print("")
print("--- 9. Clean Read Quality Summary ---")

let clean_quals = clean |> map(|r| mean_phred(r.qual))
print(f"Clean read mean quality: {round(mean(clean_quals), 1)}")
print(f"Clean read min quality:  {round(min(clean_quals), 1)}")

let gc_values = clean |> map(|r| gc_content(r.seq))
print(f"Clean read mean GC: {round(mean(gc_values) * 100, 1)}%")

# ============================================================
# 10. WRITE OUTPUT
# ============================================================
print("")
print("--- 10. Write Clean Reads ---")

write_fastq(clean, "results/clean_reads.fastq")
print(f"Wrote {len(clean)} clean reads to results/clean_reads.fastq")

# Q30 metric
let q30_count = qualities |> filter(|q| q >= 30) |> len()
let q30_pct = round(q30_count / len(reads) * 100, 1)
print(f"Q30 reads: {q30_count}/{len(reads)} ({q30_pct}%)")

print("")
print("=" * 60)
print("Day 6 complete! Your first sequencing QC pipeline.")
print("=" * 60)
