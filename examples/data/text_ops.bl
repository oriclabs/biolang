# Unix-like Text Processing Builtins
# grep, cut, paste, wc, tee, shell — familiar tools, BioLang style

# ── grep: search text with patterns ──
# grep(pattern, text, flags?) -> list of matching lines
let text = "chr1\t100\t200\tgene_A\nchr2\t300\t400\tgene_B\nchr1\t500\t600\tgene_C"
let chr1_lines = grep("chr1", text)
println("=== grep 'chr1' ===")
println(chr1_lines)

# grep_count: count matches
let n = grep_count("chr1", text)
println("Matches:", n)

# ── lines: split text into list of lines ──
let line_list = lines(text)
println("\n=== lines ===")
println("Line count:", len(line_list))
for l in line_list {
    println("  >", l)
}

# ── cut: extract columns (like Unix cut) ──
# cut(text, delimiter, fields) -> extracted text
let tsv = "name\tage\tcity\nAlice\t30\tNYC\nBob\t25\tSF"
let names = cut(tsv, "\t", "1")
println("\n=== cut (field 1) ===")
println(names)

# ── paste: join columns ──
# paste(list1, list2, delimiter?) -> joined text
let col1 = ["gene_A", "gene_B", "gene_C"]
let col2 = ["0.05", "0.01", "0.10"]
let pasted = paste(col1, col2, "\t")
println("\n=== paste ===")
println(pasted)

# ── uniq_count: count unique values ──
let items = ["apple", "banana", "apple", "cherry", "banana", "apple"]
let counts = uniq_count(items)
println("\n=== uniq_count ===")
println(counts)

# ── wc: word/line/char count ──
# wc(text) -> record {lines, words, chars}
let sample = "Hello World\nThis is BioLang\nThird line"
let stats = wc(sample)
println("\n=== wc ===")
println("Lines:", stats.lines, "Words:", stats.words, "Chars:", stats.chars)

# ── count_lines: count lines in a file ──
