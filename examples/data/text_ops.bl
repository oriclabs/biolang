# println("First 5 lines:", s)

# ── stream_concat: concatenate two streams ──
let s1 = to_stream([1, 2, 3])
let s2 = to_stream([4, 5, 6])
let combined = stream_concat(s1, s2) |> collect()
println("\n=== stream_concat ===")
println(combined)

# ── tee: write to file while passing through ──
# let data = "line1\nline2\nline3"
# let result = tee(data, "/tmp/tee_output.txt")
# println("Tee passed through:", result)

# ── shell: run system command ──
# shell(command, opts?) -> record {stdout, stderr, exit_code}
let result = shell("echo hello from shell")
println("\n=== shell ===")
println("stdout:", result.stdout)
println("exit_code:", result.exit_code)
