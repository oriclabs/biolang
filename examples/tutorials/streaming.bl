# ── 4. Streaming VCF ─────────────────────────────────────────

# VCF streaming works the same way
let pass_count = vcf("examples/sample-data/calls.vcf") |>
  filter(|v| v.filter == "PASS") |>
  count()

print(f"PASS variants (streamed): {pass_count}")

# Stream, filter, collect
vcf("examples/sample-data/calls.vcf") |>
  filter(|v| v.filter == "PASS" and v.quality >= 50.0) |>
  collect() |>
  into high_qual

print(f"High-quality PASS variants: {len(high_qual)}")

# ── 5. Reduce for Single-Pass Statistics ─────────────────────

vcf("examples/sample-data/calls.vcf") |>
  filter(|v| v.filter == "PASS") |>
  reduce(|acc, v| {
    {
      n:          acc.n + 1,
      total_qual: acc.total_qual + v.quality,
      max_qual:   max(acc.max_qual, v.quality),
    }
  }, { n: 0, total_qual: 0.0, max_qual: 0.0 }) |>
  into stats

print(f"\nStreaming reduce over VCF:")
print(f"  PASS variants: {stats.n}")
print(f"  Mean quality:  {round(stats.total_qual / stats.n, 1)}")
print(f"  Max quality:   {stats.max_qual}")

# ── 6. Streaming FASTA ───────────────────────────────────────

fasta("examples/sample-data/contigs.fa") |>
  map(|record| {
    { name: record.id, gc: gc_content(record.seq), len: len(record.seq) }
  }) |>
  collect() |>
  into gc_per_contig

print(f"\nFASTA contigs streamed: {len(gc_per_contig)}")
for entry in gc_per_contig {
  print(f"  {entry.name}: GC = {round(entry.gc, 4)}, length = {entry.len}")
}

